---
import ThemeToggle from './ThemeToggle.astro';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const nav = [
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
  { href: '/blog', label: 'Blog' },
];

function isActive(href: string) {
  if (href === '/') return path === '/';
  return path === href || path.startsWith(href + '/');
}
---

<header
  class="border-b border-ink/10 bg-paper/80 backdrop-blur-sm dark:border-cream/10 dark:bg-night/80"
>
  <div
    class="mx-auto flex max-w-page items-center justify-between gap-6 px-5 py-4 sm:px-8"
  >
    <a
      href="/"
      class="group flex items-baseline gap-2 font-display text-xl text-ink hover:text-terracotta-600 dark:text-cream dark:hover:text-terracotta-300"
    >
      <span class="italic">pranika</span>
      <span class="font-sans text-xs tracking-[0.25em] text-ink-dim uppercase dark:text-cream-soft/70"
        >jain</span
      >
    </a>

    <nav aria-label="Primary">
      <ul class="flex items-center gap-1 sm:gap-2">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
                class:list={[
                  'relative inline-block rounded px-2 py-1 font-sans text-sm transition-colors sm:px-3',
                  'text-ink/80 hover:text-terracotta-600 dark:text-cream/85 dark:hover:text-terracotta-200',
                  isActive(item.href) &&
                    'text-terracotta-600 dark:text-terracotta-200',
                ]}
              >
                {item.label}
                {isActive(item.href) && (
                  <span
                    aria-hidden="true"
                    class="absolute inset-x-2 -bottom-0.5 h-0.5 rounded-full bg-terracotta-500"
                  />
                )}
              </a>
            </li>
          ))
        }
        <li class="pl-2">
          <ThemeToggle />
        </li>
      </ul>
    </nav>
  </div>
</header>
