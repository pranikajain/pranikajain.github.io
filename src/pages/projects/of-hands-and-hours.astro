---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SketchesGallery from '../../components/projects/SketchesGallery.astro';
import Lightbox from '../../components/projects/Lightbox.astro';

const all = await getCollection('projects');
const drawer = all.filter(
  (p) => p.data.kind === 'sketches' || p.data.kind === 'craft',
);
---

<BaseLayout
  title="Of hands and hours"
  description="Sketchbook pages, paintings, things made by hand by Pranika Jain."
>
  <article class="mx-auto max-w-page px-5 py-16 sm:px-8 sm:py-24">
    <a
      href="/projects"
      class="inline-flex items-center gap-1 font-sans text-sm text-terracotta-600 underline-offset-4 hover:underline dark:text-terracotta-300"
      >&larr; All projects</a
    >

    <header class="mt-6 mb-12">
      <p
        class="flex items-center gap-3 font-mono text-xs uppercase tracking-[0.3em] text-terracotta-600 dark:text-terracotta-300"
      >
        <svg viewBox="0 0 16 16" aria-hidden="true" class="h-3 w-3">
          <path
            d="M8,1 C9,5 11,7 15,8 C11,9 9,11 8,15 C7,11 5,9 1,8 C5,7 7,5 8,1 Z"
            fill="currentColor"
          ></path>
        </svg>
        Of hands and hours
      </p>
      <h1
        class="mt-3 font-display text-4xl leading-tight tracking-tight text-ink sm:text-5xl dark:text-cream"
      >
        Of hands and <span class="italic">hours</span>.
      </h1>
      <p
        class="mt-5 font-sans text-lg text-ink-soft dark:text-cream-soft"
      >
        Sketchbook pages, paintings, things made by hand — usually a line, a
        face, a feeling I needed to put somewhere.
      </p>
    </header>

    <SketchesGallery entries={drawer} />

    <Lightbox />
  </article>
</BaseLayout>
